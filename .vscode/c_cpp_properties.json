{
  "version": 4,
  "configurations": [
    {
      "name": "Linux",
      "compilerPath": "/usr/bin/g++",
      "intelliSenseMode": "linux-gcc-x64",
      "cStandard": "c17",
      "cppStandard": "c++17",
      "includePath": [
        "${workspaceFolder}",
        "${workspaceFolder}/**",
        "/usr/include",
        "/usr/local/include",
        "/usr/include/c++/**"
      ],
      "browse": {
        "path": [
          "${workspaceFolder}",
          "${workspaceFolder}/**",
          "/usr/include",
          "/usr/local/include",
          "/usr/include/c++/**"
        ],
        "limitSymbolsToIncludedHeaders": true
      }
    }
  ]
}